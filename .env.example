# OpenRouter Configuration (Recommended)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Alternative Provider Configuration
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Database Configuration
DATABASE_PATH=:memory:

# Model Configuration
# OpenRouter Models
SLM_MODEL=openai/gpt-4o-mini
FRONTIER_MODEL=anthropic/claude-3.5-sonnet

# Alternative Models
# SLM_MODEL=gpt-4o-mini
# FRONTIER_MODEL=claude-3-5-sonnet-20241022

# Performance Configuration
MAX_CONTEXT_TOKENS=4000
ENABLE_PROGRESSIVE_DISCLOSURE=true
