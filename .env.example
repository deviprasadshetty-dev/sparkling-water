# OpenRouter Configuration (Recommended)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Model Configuration (Using FREE models by default)
# FREE models available: google/gemma-4-26b-a4b-it:free, google/gemma-4-31b-it:free
SLM_MODEL=google/gemma-4-26b-a4b-it:free
FRONTIER_MODEL=google/gemma-4-31b-it:free

# Alternative Paid Models
# SLM_MODEL=openai/gpt-4o-mini
# FRONTIER_MODEL=anthropic/claude-3.5-sonnet

# Alternative Provider Configuration
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Database Configuration
DATABASE_PATH=:memory:

# Performance Configuration
MAX_CONTEXT_TOKENS=4000
ENABLE_PROGRESSIVE_DISCLOSURE=true
